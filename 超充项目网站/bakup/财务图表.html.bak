<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>财务分析 - 千站液冷超充项目</title>
    <style>
        .chart-container {
            width: 100%;
            height: 450px;
            margin: 30px 0;
            background: rgba(26, 26, 26, 0.6);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 20px rgba(59, 130, 246, 0.1);
        }
        .financial-table {
            width: 100%;
            border-collapse: collapse;
            color: var(--wm-text-secondary);
            margin: 20px 0;
        }
        .financial-table thead {
            border-bottom: 2px solid var(--wm-info);
        }
        .financial-table th {
            padding: 15px;
            text-align: left;
            color: var(--wm-info);
            font-weight: 600;
        }
        .financial-table td {
            padding: 12px 15px;
            border-bottom: 1px solid rgba(59, 130, 246, 0.1);
        }
        .financial-table tbody tr:hover {
            background: rgba(59, 130, 246, 0.05);
        }
        .financial-table .number {
            text-align: right;
            font-family: 'Courier New', monospace;
            font-weight: 600;
        }
        .financial-table .highlight {
            color: var(--wm-info);
            font-size: 1.1em;
        }
        .chart-placeholder {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(59, 130, 246, 0.05) 100%);
            border: 2px dashed rgba(59, 130, 246, 0.3);
            border-radius: 15px;
            padding: 60px 40px;
            text-align: center;
            margin: 30px 0;
        }
        .chart-placeholder-icon {
            font-size: 64px;
            margin-bottom: 20px;
        }
    </style>
    <link rel="stylesheet" href="../world-monitor-theme.css">
</head>
<body class="no-transition">
    <div class="wm-container">
    <header class="wm-header">
        <div class="wm-header-content">
            <a href="../index.html" class="wm-btn">← 返回首页</a>
        </div>
    </header>

    <main class="wm-main">
        <div class="wm-panel">
            <h1 style="font-size: 48px; margin-bottom: 20px;">财务分析</h1>
            <p style="font-size: 20px; color: var(--wm-text-secondary); max-width: 900px; margin: 0 auto;">Financial Analysis</p>
        </div>

        <!-- 投资概览 -->
        <section class="wm-panel">
            <h2>投资规模与结构</h2>
            <div class="wm-card" style="margin-bottom: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">总投资概览</h3>
                <div class="grid grid-4">
                    <div class="wm-metric">
                        <div class="wm-metric-value">28亿元</div>
                        <div class="wm-metric-label">总投资额</div>
                    </div>
                    <div class="wm-metric">
                        <div class="wm-metric-value">280万元</div>
                        <div class="wm-metric-label">单站投资</div>
                    </div>
                    <div class="wm-metric">
                        <div class="wm-metric-value">1000座</div>
                        <div class="wm-metric-label">建设规模</div>
                    </div>
                    <div class="wm-metric">
                        <div class="wm-metric-value">5年</div>
                        <div class="wm-metric-label">建设周期</div>
                    </div>
                </div>
            </div>

            <div class="wm-card">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">投资构成明细</h3>
                <table class="financial-table">
                    <thead>
                        <tr>
                            <th>投资类别</th>
                            <th class="number">金额（亿元）</th>
                            <th class="number">占比</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>设备投资</strong></td>
                            <td class="number highlight">168</td>
                            <td class="number">60%</td>
                        </tr>
                        <tr style="color: var(--wm-text-secondary); opacity: 0.8;">
                            <td style="padding-left: 30px;">• 充电桩设备</td>
                            <td class="number">126</td>
                            <td class="number">45%</td>
                        </tr>
                        <tr style="color: var(--wm-text-secondary); opacity: 0.8;">
                            <td style="padding-left: 30px;">• 电力设备</td>
                            <td class="number">28</td>
                            <td class="number">10%</td>
                        </tr>
                        <tr style="color: var(--wm-text-secondary); opacity: 0.8;">
                            <td style="padding-left: 30px;">• 辅助设备</td>
                            <td class="number">14</td>
                            <td class="number">5%</td>
                        </tr>
                        <tr>
                            <td><strong>土建工程</strong></td>
                            <td class="number highlight">56</td>
                            <td class="number">20%</td>
                        </tr>
                        <tr>
                            <td><strong>运营资金</strong></td>
                            <td class="number highlight">42</td>
                            <td class="number">15%</td>
                        </tr>
                        <tr>
                            <td><strong>其他费用</strong></td>
                            <td class="number highlight">14</td>
                            <td class="number">5%</td>
                        </tr>
                        <tr style="border-top: 2px solid var(--wm-info);">
                            <td><strong>合计</strong></td>
                            <td class="number highlight" style="font-size: 1.3em;">28</td>
                            <td class="number">100%</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- 投资构成饼图 -->
            <div class="wm-card" style="margin-top: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">投资构成可视化</h3>
                <div id="investmentChart" class="chart-container"></div>
            </div>
        </section>

        <!-- 收入预测 -->
        <section class="wm-panel">
            <h2>收入预测模型</h2>
            
            <div class="wm-card" style="margin-bottom: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">单站年收入预测（万元）</h3>
                <table class="financial-table">
                    <thead>
                        <tr>
                            <th>年份</th>
                            <th class="number">充电收入</th>
                            <th class="number">增值服务</th>
                            <th class="number">政府补贴</th>
                            <th class="number">总收入</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>第1年</td>
                            <td class="number">336</td>
                            <td class="number">42</td>
                            <td class="number">84</td>
                            <td class="number highlight">462</td>
                        </tr>
                        <tr>
                            <td>第2年</td>
                            <td class="number">504</td>
                            <td class="number">63</td>
                            <td class="number">42</td>
                            <td class="number highlight">609</td>
                        </tr>
                        <tr>
                            <td>第3年</td>
                            <td class="number">672</td>
                            <td class="number">84</td>
                            <td class="number">21</td>
                            <td class="number highlight">777</td>
                        </tr>
                        <tr>
                            <td>第4年</td>
                            <td class="number">840</td>
                            <td class="number">105</td>
                            <td class="number">0</td>
                            <td class="number highlight">945</td>
                        </tr>
                        <tr>
                            <td>第5年</td>
                            <td class="number">1008</td>
                            <td class="number">126</td>
                            <td class="number">0</td>
                            <td class="number highlight">1134</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- 单站收入预测图 -->
            <div class="wm-card" style="margin-top: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">单站年收入增长趋势</h3>
                <div id="revenueChart" class="chart-container"></div>
            </div>

            <div class="wm-grid wm-grid-2">
                <div class="wm-card">
                    <h3 style="color: var(--wm-info); margin-bottom: 20px;">1000站年总收入预测</h3>
                    <table class="financial-table">
                        <thead>
                            <tr>
                                <th>年份</th>
                                <th class="number">年总收入（亿元）</th>
                                <th class="number">累计收入（亿元）</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>第1年</td>
                                <td class="number">46.2</td>
                                <td class="number highlight">46.2</td>
                            </tr>
                            <tr>
                                <td>第2年</td>
                                <td class="number">60.9</td>
                                <td class="number highlight">107.1</td>
                            </tr>
                            <tr>
                                <td>第3年</td>
                                <td class="number">77.7</td>
                                <td class="number highlight">184.8</td>
                            </tr>
                            <tr>
                                <td>第4年</td>
                                <td class="number">94.5</td>
                                <td class="number highlight">279.3</td>
                            </tr>
                            <tr>
                                <td>第5年</td>
                                <td class="number">113.4</td>
                                <td class="number highlight">392.7</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="wm-card">
                    <h3 style="color: var(--wm-info); margin-bottom: 20px;">运营成本构成</h3>
                    <ul style="list-style: none; padding: 0;">
                        <li style="padding: 15px 0; border-bottom: 1px solid rgba(59, 130, 246, 0.2);">
                            <strong>电费成本：</strong><span style="color: var(--wm-info); font-size: 1.2em;">40%</span> 占收入比
                        </li>
                        <li style="padding: 15px 0; border-bottom: 1px solid rgba(59, 130, 246, 0.2);">
                            <strong>人工成本：</strong><span style="color: var(--wm-info); font-size: 1.2em;">15%</span> 占收入比
                        </li>
                        <li style="padding: 15px 0; border-bottom: 1px solid rgba(59, 130, 246, 0.2);">
                            <strong>场地租金：</strong><span style="color: var(--wm-info); font-size: 1.2em;">10%</span> 占收入比
                        </li>
                        <li style="padding: 15px 0; border-bottom: 1px solid rgba(59, 130, 246, 0.2);">
                            <strong>设备维护：</strong><span style="color: var(--wm-info); font-size: 1.2em;">8%</span> 占收入比
                        </li>
                        <li style="padding: 15px 0;">
                            <strong>其他费用：</strong><span style="color: var(--wm-info); font-size: 1.2em;">7%</span> 占收入比
                        </li>
                    </ul>
                </div>
            </div>

            <!-- 1000站总收入增长图 -->
            <div class="wm-card" style="margin-top: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">1000站总收入增长趋势</h3>
                <div id="totalRevenueChart" class="chart-container"></div>
            </div>
        </section>

        <!-- 盈利能力 -->
        <section class="wm-panel">
            <h2>盈利能力分析</h2>
            <div class="wm-card">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">利润预测（单站/年）</h3>
                <table class="financial-table">
                    <thead>
                        <tr>
                            <th>年份</th>
                            <th class="number">收入</th>
                            <th class="number">成本</th>
                            <th class="number">利润</th>
                            <th class="number">利润率</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>第1年</td>
                            <td class="number">462万</td>
                            <td class="number">271万</td>
                            <td class="number highlight">191万</td>
                            <td class="number">41.3%</td>
                        </tr>
                        <tr>
                            <td>第2年</td>
                            <td class="number">609万</td>
                            <td class="number">405万</td>
                            <td class="number highlight">204万</td>
                            <td class="number">33.5%</td>
                        </tr>
                        <tr>
                            <td>第3年</td>
                            <td class="number">777万</td>
                            <td class="number">542万</td>
                            <td class="number highlight">235万</td>
                            <td class="number">30.2%</td>
                        </tr>
                        <tr>
                            <td>第4年</td>
                            <td class="number">945万</td>
                            <td class="number">676万</td>
                            <td class="number highlight">269万</td>
                            <td class="number">28.5%</td>
                        </tr>
                        <tr>
                            <td>第5年</td>
                            <td class="number">1134万</td>
                            <td class="number">813万</td>
                            <td class="number highlight">321万</td>
                            <td class="number">28.3%</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- 利润预测图 -->
            <div class="wm-card" style="margin-top: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">单站利润增长趋势</h3>
                <div id="profitChart" class="chart-container"></div>
            </div>

            <div class="wm-card" style="margin-top: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">1000站总利润预测</h3>
                <div class="grid grid-4">
                    <div class="wm-metric">
                        <div class="wm-metric-value">19.1亿元</div>
                        <div class="wm-metric-label">第1年利润</div>
                    </div>
                    <div class="wm-metric">
                        <div class="wm-metric-value">63.0亿元</div>
                        <div class="wm-metric-label">前3年累计</div>
                    </div>
                    <div class="wm-metric">
                        <div class="wm-metric-value">89.9亿元</div>
                        <div class="wm-metric-label">前4年累计</div>
                    </div>
                    <div class="wm-metric">
                        <div class="wm-metric-value">122.0亿元</div>
                        <div class="wm-metric-label">5年累计利润</div>
                    </div>
                </div>
            </div>

            <!-- 1000站总利润图 -->
            <div class="wm-card" style="margin-top: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">1000站总利润增长趋势</h3>
                <div id="totalProfitChart" class="chart-container"></div>
            </div>
        </section>

        <!-- 现金流分析 -->
        <section class="wm-panel">
            <h2>现金流分析</h2>
            <div class="wm-card">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">现金流预测（1000站）</h3>
                <table class="financial-table">
                    <thead>
                        <tr>
                            <th>年份</th>
                            <th class="number">经营现金流（亿元）</th>
                            <th class="number">投资现金流（亿元）</th>
                            <th class="number">净现金流（亿元）</th>
                            <th class="number">累计现金流（亿元）</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>第0年</td>
                            <td class="number">0</td>
                            <td class="number">-28.0</td>
                            <td class="number highlight" style="color: #ff6b6b;">-28.0</td>
                            <td class="number" style="color: #ff6b6b;">-28.0</td>
                        </tr>
                        <tr>
                            <td>第1年</td>
                            <td class="number">19.1</td>
                            <td class="number">-5.6</td>
                            <td class="number highlight">13.5</td>
                            <td class="number" style="color: #ff6b6b;">-14.5</td>
                        </tr>
                        <tr>
                            <td>第2年</td>
                            <td class="number">20.4</td>
                            <td class="number">-5.6</td>
                            <td class="number highlight">14.8</td>
                            <td class="number" style="color: var(--wm-info);">0.3</td>
                        </tr>
                        <tr>
                            <td>第3年</td>
                            <td class="number">23.5</td>
                            <td class="number">-5.6</td>
                            <td class="number highlight">17.9</td>
                            <td class="number" style="color: var(--wm-info);">18.2</td>
                        </tr>
                        <tr>
                            <td>第4年</td>
                            <td class="number">26.9</td>
                            <td class="number">-5.6</td>
                            <td class="number highlight">21.3</td>
                            <td class="number" style="color: var(--wm-info);">39.5</td>
                        </tr>
                        <tr>
                            <td>第5年</td>
                            <td class="number">32.1</td>
                            <td class="number">-5.6</td>
                            <td class="number highlight">26.5</td>
                            <td class="number" style="color: var(--wm-info);">66.0</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- 现金流图 -->
            <div class="wm-card" style="margin-top: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">现金流可视化分析</h3>
                <div id="cashflowChart" class="chart-container"></div>
            </div>
        </section>

        <!-- 关键财务指标 -->
        <section class="wm-panel">
            <h2>关键财务指标</h2>
            <div class="wm-grid wm-grid-2">
                <div class="wm-card">
                    <h3 style="color: var(--wm-info); margin-bottom: 20px;">投资回报指标</h3>
                    <div style="background: rgba(59, 130, 246, 0.1); padding: 20px; border-radius: 10px; margin-bottom: 15px;">
                        <div style="font-size: 14px; color: var(--wm-text-secondary);">投资回收期</div>
                        <div style="font-size: 36px; color: var(--wm-info); font-weight: bold; margin-top: 5px;">4.5年</div>
                    </div>
                    <div style="background: rgba(59, 130, 246, 0.1); padding: 20px; border-radius: 10px; margin-bottom: 15px;">
                        <div style="font-size: 14px; color: var(--wm-text-secondary);">净现值 (NPV@12%)</div>
                        <div style="font-size: 36px; color: var(--wm-info); font-weight: bold; margin-top: 5px;">12.4亿元</div>
                    </div>
                    <div style="background: rgba(59, 130, 246, 0.1); padding: 20px; border-radius: 10px; margin-bottom: 15px;">
                        <div style="font-size: 14px; color: var(--wm-text-secondary);">内部收益率 (IRR)</div>
                        <div style="font-size: 36px; color: var(--wm-info); font-weight: bold; margin-top: 5px;">42.8%</div>
                    </div>
                    <div style="background: rgba(59, 130, 246, 0.1); padding: 20px; border-radius: 10px;">
                        <div style="font-size: 14px; color: var(--wm-text-secondary);">投资回报率 (ROI/10年)</div>
                        <div style="font-size: 36px; color: var(--wm-info); font-weight: bold; margin-top: 5px;">435%</div>
                    </div>
                </div>

                <div class="wm-card">
                    <h3 style="color: var(--wm-info); margin-bottom: 20px;">盈利能力指标</h3>
                    <ul style="list-style: none; padding: 0;">
                        <li style="padding: 20px 0; border-bottom: 1px solid rgba(59, 130, 246, 0.2);">
                            <div style="font-size: 16px; color: var(--wm-text-secondary);">毛利率（第5年）</div>
                            <div style="font-size: 28px; color: var(--wm-info); font-weight: bold;">28.3%</div>
                        </li>
                        <li style="padding: 20px 0; border-bottom: 1px solid rgba(59, 130, 246, 0.2);">
                            <div style="font-size: 16px; color: var(--wm-text-secondary);">净利率（第5年）</div>
                            <div style="font-size: 28px; color: var(--wm-info); font-weight: bold;">22.1%</div>
                        </li>
                        <li style="padding: 20px 0; border-bottom: 1px solid rgba(59, 130, 246, 0.2);">
                            <div style="font-size: 16px; color: var(--wm-text-secondary);">资产收益率 (ROA)</div>
                            <div style="font-size: 28px; color: var(--wm-info); font-weight: bold;">15.2%</div>
                        </li>
                        <li style="padding: 20px 0;">
                            <div style="font-size: 16px; color: var(--wm-text-secondary);">净资产收益率 (ROE)</div>
                            <div style="font-size: 28px; color: var(--wm-info); font-weight: bold;">25.3%</div>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- 敏感性分析 -->
        <section class="wm-panel">
            <h2>敏感性分析</h2>
            <div class="wm-card">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">关键变量影响分析</h3>
                <div class="wm-grid wm-grid-3">
                    <div style="background: rgba(59, 130, 246, 0.1); padding: 25px; border-radius: 10px;">
                        <h4 style="color: var(--wm-info); margin-bottom: 15px;">充电量变动 ±20%</h4>
                        <p style="color: var(--wm-text-secondary); margin-bottom: 10px;"><strong>IRR范围：</strong></p>
                        <div style="font-size: 24px; color: var(--wm-info); font-weight: bold; margin-bottom: 15px;">35.6% - 50.2%</div>
                        <p style="color: var(--wm-text-secondary);"><strong>回收期：</strong>3.8年 - 5.2年</p>
                    </div>
                    <div style="background: rgba(59, 130, 246, 0.1); padding: 25px; border-radius: 10px;">
                        <h4 style="color: var(--wm-info); margin-bottom: 15px;">电价变动 ±20%</h4>
                        <p style="color: var(--wm-text-secondary); margin-bottom: 10px;"><strong>IRR范围：</strong></p>
                        <div style="font-size: 24px; color: var(--wm-info); font-weight: bold; margin-bottom: 15px;">38.1% - 47.5%</div>
                        <p style="color: var(--wm-text-secondary);"><strong>回收期：</strong>4.1年 - 5.0年</p>
                    </div>
                    <div style="background: rgba(59, 130, 246, 0.1); padding: 25px; border-radius: 10px;">
                        <h4 style="color: var(--wm-info); margin-bottom: 15px;">服务费变动 ±20%</h4>
                        <p style="color: var(--wm-text-secondary); margin-bottom: 10px;"><strong>IRR范围：</strong></p>
                        <div style="font-size: 24px; color: var(--wm-info); font-weight: bold; margin-bottom: 15px;">32.4% - 53.7%</div>
                        <p style="color: var(--wm-text-secondary);"><strong>回收期：</strong>3.5年 - 5.8年</p>
                    </div>
                </div>
            </div>

            <!-- 敏感性分析图 -->
            <div class="wm-card" style="margin-top: 30px;">
                <h3 style="color: var(--wm-info); margin-bottom: 20px;">敏感性分析可视化</h3>
                <div id="sensitivityChart" class="chart-container"></div>
            </div>
        </section>

        <!-- CTA -->
        <section class="cta-section" style="background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0.05) 100%); padding: 80px 40px; border-radius: 20px; text-align: center; margin: 80px 0; border: 2px solid rgba(59, 130, 246, 0.3);">
            <h2>需要详细财务模型？</h2>
            <p style="font-size: 18px; margin: 30px 0; color: var(--wm-text-secondary);">联系我们获取完整的财务分析报告和投资测算模型</p>
            <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
                <a href="../联系合作.html" class="btn btn-primary">联系合作</a>
                <a href="商业计划书投资者版.html" class="btn btn-secondary">查看商业计划书</a>
            </div>
        </section>

        </main>
<footer style="text-align: center; padding: 40px 0; color: var(--wm-text-secondary); opacity: 0.7;">
            <p>© 2025 KeyTrader. All rights reserved.</p>
            <p style="font-size: 14px; margin-top: 10px;">
                千站液冷超充项目 - 财务分析
            </p>
        </footer>
    </div>

    <!-- 加载ECharts配置 -->
    <script src="js/echarts-config.js"></script>

    <script>
        // 等待DOM完全加载后再初始化图表
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM已加载，开始初始化图表...');

            // 投资构成饼图（数据来自原文）
            const investmentChart = initInkGoldChartResponsive('investmentChart', {
            title: { text: '投资构成分布（28亿元）', left: 'center' },
            tooltip: { trigger: 'item', formatter: '{b}: {c}亿元 ({d}%)' },
            legend: { orient: 'vertical', left: 'left', textStyle: { color: '#F5F5DC' } },
            series: [{
                name: '投资构成',
                type: 'pie',
                radius: ['40%', '70%'],
                center: ['60%', '50%'],
                data: [
                    {value: 168, name: '设备投资 60%'},
                    {value: 56, name: '土建工程 20%'},
                    {value: 42, name: '运营资金 15%'},
                    {value: 14, name: '其他费用 5%'}
                ]
            }]
        });

        // 单站收入预测图
        const revenueChart = initInkGoldChartResponsive('revenueChart', {
            title: { text: '单站年收入预测（万元）', left: 'center' },
            tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
            legend: { data: ['充电收入', '增值服务', '政府补贴'], textStyle: { color: '#D4AF37' }, top: 'bottom' },
            xAxis: { type: 'category', data: ['第1年', '第2年', '第3年', '第4年', '第5年'], axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } } },
            yAxis: { type: 'value', name: '金额（万元）', axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } }, splitLine: { lineStyle: { color: 'rgba(59, 130, 246, 0.1)', type: 'dashed' } } },
            series: [
                { name: '充电收入', type: 'bar', stack: 'total', data: [336, 504, 672, 840, 1008], itemStyle: { color: '#D4AF37' } },
                { name: '增值服务', type: 'bar', stack: 'total', data: [42, 63, 84, 105, 126], itemStyle: { color: '#8B7355' } },
                { name: '政府补贴', type: 'bar', stack: 'total', data: [84, 42, 21, 0, 0], itemStyle: { color: '#DAA520' } }
            ]
        });

        // 1000站总收入增长图
        const totalRevenueChart = initInkGoldChartResponsive('totalRevenueChart', {
            title: { text: '1000站年总收入增长趋势', left: 'center' },
            tooltip: { trigger: 'axis', formatter: '{b}<br/>年总收入: {c}亿元' },
            xAxis: { type: 'category', data: ['第1年', '第2年', '第3年', '第4年', '第5年'], axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } } },
            yAxis: { type: 'value', name: '金额（亿元）', axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } }, splitLine: { lineStyle: { color: 'rgba(59, 130, 246, 0.1)', type: 'dashed' } } },
            series: [{
                name: '年总收入',
                type: 'line',
                data: [46.2, 60.9, 77.7, 94.5, 113.4],
                itemStyle: { color: '#D4AF37' },
                lineStyle: { width: 4 },
                areaStyle: {
                    color: { type: 'linear', x: 0, y: 0, x2: 0, y2: 1, colorStops: [{offset: 0, color: 'rgba(59, 130, 246, 0.3)'}, {offset: 1, color: 'rgba(59, 130, 246, 0.05)'}] }
                },
                markPoint: { data: [{type: 'max', name: '最大值'}, {type: 'min', name: '最小值'}] }
            }]
        });

        // 单站利润预测图
        const profitChart = initInkGoldChartResponsive('profitChart', {
            title: { text: '单站利润预测（万元/年）', left: 'center' },
            tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
            legend: { data: ['收入', '成本', '利润'], textStyle: { color: '#D4AF37' }, top: 'bottom' },
            xAxis: { type: 'category', data: ['第1年', '第2年', '第3年', '第4年', '第5年'], axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } } },
            yAxis: { type: 'value', name: '金额（万元）', axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } }, splitLine: { lineStyle: { color: 'rgba(59, 130, 246, 0.1)', type: 'dashed' } } },
            series: [
                { name: '收入', type: 'bar', data: [462, 609, 777, 945, 1134], itemStyle: { color: '#D4AF37' } },
                { name: '成本', type: 'bar', data: [271, 405, 542, 676, 813], itemStyle: { color: '#8B7355' } },
                { name: '利润', type: 'line', data: [191, 204, 235, 269, 321], itemStyle: { color: '#F5F5DC' }, lineStyle: { width: 3 } }
            ]
        });

        // 1000站总利润图
        const totalProfitChart = initInkGoldChartResponsive('totalProfitChart', {
            title: { text: '1000站总利润增长趋势', left: 'center' },
            tooltip: { trigger: 'axis', formatter: '{b}<br/>总利润: {c}亿元' },
            xAxis: { type: 'category', data: ['第1年', '第2年', '第3年', '第4年', '第5年'], axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } } },
            yAxis: { type: 'value', name: '金额（亿元）', axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } }, splitLine: { lineStyle: { color: 'rgba(59, 130, 246, 0.1)', type: 'dashed' } } },
            series: [{
                name: '总利润',
                type: 'bar',
                data: [19.1, 20.4, 23.5, 26.9, 32.1],
                itemStyle: {
                    color: function(params) {
                        const colors = ['#CD853F', '#DAA520', '#D4AF37', '#B8860B', '#D4AF37'];
                        return colors[params.dataIndex];
                    }
                },
                label: { show: true, position: 'top', formatter: '{c}亿', color: '#F5F5DC' }
            }]
        });

        // 现金流图
        const cashflowChart = initInkGoldChartResponsive('cashflowChart', {
            title: { text: '现金流分析（1000站/亿元）', left: 'center' },
            tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
            legend: { data: ['经营现金流', '净现金流', '累计现金流'], textStyle: { color: '#D4AF37' }, top: 'bottom' },
            xAxis: { type: 'category', data: ['第0年', '第1年', '第2年', '第3年', '第4年', '第5年'], axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } } },
            yAxis: { type: 'value', name: '金额（亿元）', axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } }, splitLine: { lineStyle: { color: 'rgba(59, 130, 246, 0.1)', type: 'dashed' } } },
            series: [
                { name: '经营现金流', type: 'bar', data: [0, 19.1, 20.4, 23.5, 26.9, 32.1], itemStyle: { color: '#D4AF37' } },
                { name: '净现金流', type: 'bar', data: [-28, 13.5, 14.8, 17.9, 21.3, 26.5], itemStyle: { color: '#8B7355' } },
                { name: '累计现金流', type: 'line', data: [-28, -14.5, 0.3, 18.2, 39.5, 66], itemStyle: { color: '#F5F5DC' }, lineStyle: { width: 3 }, markLine: { data: [{ yAxis: 0, name: '盈亏平衡', lineStyle: { color: '#4CAF50', type: 'dashed' } }] } }
            ]
        });

        // 敏感性分析图
        const sensitivityChart = initInkGoldChartResponsive('sensitivityChart', {
            title: { text: '敏感性分析 - IRR范围对比', left: 'center' },
            tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
            xAxis: { type: 'category', data: ['充电量变动', '电价变动', '服务费变动'], axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } } },
            yAxis: { type: 'value', name: 'IRR（%）', axisLabel: { color: '#F5F5DC' }, axisLine: { lineStyle: { color: '#D4AF37' } }, splitLine: { lineStyle: { color: 'rgba(59, 130, 246, 0.1)', type: 'dashed' } } },
            series: [
                { name: '最低IRR', type: 'bar', data: [35.6, 38.1, 32.4], itemStyle: { color: '#CD853F' } },
                { name: '最高IRR', type: 'bar', data: [50.2, 47.5, 53.7], itemStyle: { color: '#D4AF37' } },
                { name: '基准IRR', type: 'line', data: [42.8, 42.8, 42.8], itemStyle: { color: '#F5F5DC' }, lineStyle: { width: 3, type: 'dashed' } }
            ]
        });

        // 注意：响应式处理已由echarts-config.js统一管理

        console.log('所有图表初始化完成！');
        }); // DOMContentLoaded结束
    </script>

    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('visible');
            });
        }, {threshold: 0.1, rootMargin: '0px 0px -50px 0px'});
        document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>
</body>
</html>
