<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>交互式计算器 - 千站液冷超充项目</title>
    <style>
        .calculator-container {
            background: rgba(26, 26, 26, 0.8);
            border-radius: 20px;
            padding: 40px;
            margin: 30px 0;
            border: 2px solid rgba(59, 130, 246, 0.3);
        }
        .input-group {
            margin-bottom: 25px;
        }
        .input-group label {
            display: block;
            color: var(--wm-info);
            font-weight: 600;
            margin-bottom: 10px;
            font-size: 16px;
        }
        .input-group input[type="range"] {
            width: 100%;
            height: 8px;
            background: rgba(59, 130, 246, 0.2);
            border-radius: 5px;
            outline: none;
            -webkit-appearance: none;
        }
        .input-group input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 20px;
            height: 20px;
            background: var(--wm-info);
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 0 10px var(--wm-info);
        }
        .input-group input[type="number"] {
            width: 100%;
            padding: 12px;
            background: rgba(59, 130, 246, 0.1);
            border: 2px solid rgba(59, 130, 246, 0.3);
            border-radius: 8px;
            color: var(--wm-text-secondary);
            font-size: 16px;
        }
        .input-group input[type="number"]:focus {
            outline: none;
            border-color: var(--wm-info);
        }
        .range-value {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 10px;
        }
        .range-value .current {
            font-size: 24px;
            color: var(--wm-info);
            font-weight: bold;
        }
        .range-value .unit {
            color: var(--wm-text-secondary);
            margin-left: 5px;
        }
        .results-box {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0.05) 100%);
            border-radius: 15px;
            padding: 30px;
            border: 2px solid rgba(59, 130, 246, 0.3);
        }
        .result-item {
            text-align: center;
            padding: 20px;
            margin-bottom: 20px;
            background: rgba(26, 26, 26, 0.6);
            border-radius: 10px;
        }
        .result-item:last-child {
            margin-bottom: 0;
        }
        .result-label {
            font-size: 14px;
            color: var(--wm-text-secondary);
            margin-bottom: 10px;
        }
        .result-value {
            font-size: 36px;
            color: var(--wm-info);
            font-weight: bold;
        }
        .result-unit {
            font-size: 16px;
            color: var(--wm-text-secondary);
            margin-left: 5px;
        }
        .calculate-btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, var(--wm-info) 0%, var(--primary-gold-light) 100%);
            color: var(--wm-bg);
            border: none;
            border-radius: 10px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px var(--shadow-gold);
        }
        .calculate-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px var(--shadow-gold);
        }
        .preset-buttons {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .preset-btn {
            padding: 10px 20px;
            background: rgba(59, 130, 246, 0.2);
            border: 2px solid rgba(59, 130, 246, 0.3);
            border-radius: 8px;
            color: var(--wm-text-secondary);
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 14px;
        }
        .preset-btn:hover, .preset-btn.active {
            background: rgba(59, 130, 246, 0.3);
            border-color: var(--wm-info);
        }
    </style>
    <link rel="stylesheet" href="../world-monitor-theme.css">
</head>
<body class="no-transition">
    <div class="wm-container">
    <header class="wm-header">
        <div class="wm-header-content">
            <a href="../index.html" class="wm-btn">← 返回首页</a>
        </div>
    </header>

    <main class="wm-main">
        <div class="wm-panel">
            <h1 style="font-size: 48px; margin-bottom: 20px;">交互式计算器</h1>
            <p style="font-size: 20px; color: var(--wm-text-secondary); max-width: 900px; margin: 0 auto;">投资回报实时计算工具</p>
        </div>

        <section class="wm-panel">
            <h2>投资回报计算器</h2>
            <p style="color: var(--wm-text-secondary); margin: 20px 0;">
                调整下方参数，实时查看投资回报分析。本计算器基于千站液冷超充项目财务模型。
            </p>

            <div class="wm-grid wm-grid-2">
                <!-- 输入参数 -->
                <div class="calculator-container">
                    <h3 style="color: var(--wm-info); margin-bottom: 25px; text-align: center;">输入参数</h3>

                    <div class="input-group">
                        <label>投资规模（座）</label>
                        <div class="preset-buttons">
                            <button class="preset-btn active" onclick="setStations(100)">100座</button>
                            <button class="preset-btn" onclick="setStations(500)">500座</button>
                            <button class="preset-btn" onclick="setStations(1000)">1000座</button>
                        </div>
                        <input type="range" id="stations" min="10" max="1000" value="1000" oninput="updateCalculation()">
                        <div class="range-value">
                            <span>当前：<span class="current" id="stationsValue">1000</span><span class="unit">座</span></span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>单站投资（万元）</label>
                        <input type="range" id="investmentPerStation" min="200" max="400" value="280" oninput="updateCalculation()">
                        <div class="range-value">
                            <span>当前：<span class="current" id="investmentPerStationValue">280</span><span class="unit">万元</span></span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>日均充电量（度/站）</label>
                        <input type="range" id="dailyCharging" min="500" max="3000" value="1500" oninput="updateCalculation()">
                        <div class="range-value">
                            <span>当前：<span class="current" id="dailyChargingValue">1500</span><span class="unit">度</span></span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>服务费（元/度）</label>
                        <input type="range" id="serviceFee" min="0.3" max="1.0" step="0.05" value="0.6" oninput="updateCalculation()">
                        <div class="range-value">
                            <span>当前：<span class="current" id="serviceFeeValue">0.60</span><span class="unit">元/度</span></span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>运营成本率（%）</label>
                        <input type="range" id="operatingCost" min="50" max="80" value="65" oninput="updateCalculation()">
                        <div class="range-value">
                            <span>当前：<span class="current" id="operatingCostValue">65</span><span class="unit">%</span></span>
                        </div>
                    </div>
                </div>

                <!-- 计算结果 -->
                <div class="calculator-container">
                    <h3 style="color: var(--wm-info); margin-bottom: 25px; text-align: center;">计算结果</h3>

                    <div class="results-box">
                        <div class="result-item">
                            <div class="result-label">总投资额</div>
                            <div>
                                <span class="result-value" id="totalInvestment">28.0</span>
                                <span class="result-unit">亿元</span>
                            </div>
                        </div>

                        <div class="result-item">
                            <div class="result-label">年营业收入</div>
                            <div>
                                <span class="result-value" id="annualRevenue">3.29</span>
                                <span class="result-unit">亿元</span>
                            </div>
                        </div>

                        <div class="result-item">
                            <div class="result-label">年净利润</div>
                            <div>
                                <span class="result-value" id="annualProfit">1.15</span>
                                <span class="result-unit">亿元</span>
                            </div>
                        </div>

                        <div class="result-item">
                            <div class="result-label">投资回收期</div>
                            <div>
                                <span class="result-value" id="paybackPeriod">4.5</span>
                                <span class="result-unit">年</span>
                            </div>
                        </div>

                        <div class="result-item">
                            <div class="result-label">内部收益率（IRR）</div>
                            <div>
                                <span class="result-value" id="irr">42.8</span>
                                <span class="result-unit">%</span>
                            </div>
                        </div>

                        <div class="result-item">
                            <div class="result-label">10年回报率（ROI）</div>
                            <div>
                                <span class="result-value" id="roi">435</span>
                                <span class="result-unit">%</span>
                            </div>
                        </div>
                    </div>

                    <button class="calculate-btn" onclick="updateCalculation()" style="margin-top: 20px;">
                        🔄 重新计算
                    </button>
                </div>
            </div>
        </section>

        <!-- 敏感性分析 -->
        <section class="wm-panel">
            <h2>敏感性分析</h2>
            <div class="wm-card">
                <p style="color: var(--wm-text-secondary); margin-bottom: 20px;">
                    调整关键参数，观察对IRR和投资回收期的影响
                </p>

                <div class="wm-grid wm-grid-3">
                    <div style="padding: 20px; background: rgba(59, 130, 246, 0.1); border-radius: 10px;">
                        <h4 style="color: var(--wm-info); margin-bottom: 15px;">充电量影响</h4>
                        <p style="color: var(--wm-text-secondary); font-size: 14px; margin-bottom: 10px;">充电量 ±20%</p>
                        <div style="font-size: 20px; color: var(--wm-info); font-weight: bold; margin-bottom: 5px;">
                            IRR: <span id="sensitivityCharging">32.4% - 53.7%</span>
                        </div>
                        <p style="color: var(--wm-text-secondary); font-size: 12px;">回收期: 3.5 - 5.8年</p>
                    </div>

                    <div style="padding: 20px; background: rgba(59, 130, 246, 0.1); border-radius: 10px;">
                        h4 style="color: var(--wm-info); margin-bottom: 15px;">服务费影响</h4>
                        <p style="color: var(--wm-text-secondary); font-size: 14px; margin-bottom: 10px;">服务费 ±20%</p>
                        <div style="font-size: 20px; color: var(--wm-info); font-weight: bold; margin-bottom: 5px;">
                            IRR: <span id="sensitivityFee">32.4% - 53.7%</span>
                        </div>
                        <p style="color: var(--wm-text-secondary); font-size: 12px;">回收期: 3.5 - 5.8年</p>
                    </div>

                    <div style="padding: 20px; background: rgba(59, 130, 246, 0.1); border-radius: 10px;">
                        h4 style="color: var(--wm-info); margin-bottom: 15px;">投资成本影响</h4>
                        <p style="color: var(--wm-text-secondary); font-size: 14px; margin-bottom: 10px;">投资额 ±20%</p>
                        <div style="font-size: 20px; color: var(--wm-info); font-weight: bold; margin-bottom: 5px;">
                            IRR: <span id="sensitivityInvestment">38.1% - 47.5%</span>
                        </div>
                        <p style="color: var(--wm-text-secondary); font-size: 12px;">回收期: 4.1 - 5.0年</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- 使用说明 -->
        <section class="wm-panel">
            h2>使用说明</h2>
            <div class="wm-card">
                <div class="wm-grid wm-grid-2">
                    <div>
                        <h3 style="color: var(--wm-info); margin-bottom: 15px;">参数说明</h3>
                        <ul style="color: var(--wm-text-secondary); line-height: 2;">
                            <li><strong>投资规模：</strong>计划建设的充电站数量</li>
                            <li><strong>单站投资：</strong>每座充电站的建设成本</li>
                            <li><strong>日均充电量：</strong>每站每天的平均充电量</li>
                            <li><strong>服务费：</strong>收取的充电服务费单价</li>
                            <li><strong>运营成本率：</strong>运营成本占收入的比例</li>
                        </ul>
                    </div>
                    <div>
                        <h3 style="color: var(--wm-info); margin-bottom: 15px;">计算方法</h3>
                        <ul style="color: var(--wm-text-secondary); line-height: 2;">
                            <li>基于项目实际财务模型</li>
                            <li>考虑建设期和运营期现金流</li>
                            <li>采用标准IRR计算方法</li>
                            <li>敏感性分析参考±20%波动</li>
                            <li>计算结果仅供参考</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="cta-section" style="background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0.05) 100%); padding: 80px 40px; border-radius: 20px; text-align: center; margin: 80px 0; border: 2px solid rgba(59, 130, 246, 0.3);">
            <h2>需要更详细的财务模型？</h2>
            <p style="font-size: 18px; margin: 30px 0; color: var(--wm-text-secondary);">
                联系我们获取完整的Excel财务模型和投资测算工具
            </p>
            <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
                <a href="../联系合作.html" class="btn btn-primary">联系合作</a>
                <a href="财务图表.html" class="btn btn-secondary">查看详细财务分析</a>
            </div>
        </section>

        </main>
<footer style="text-align: center; padding: 40px 0; color: var(--wm-text-secondary); opacity: 0.7;">
            <p>© 2025 KeyTrader. All rights reserved.</p>
            <p style="font-size: 14px; margin-top: 10px;">
                千站液冷超充项目 - 交互式计算器
            </p>
        </footer>
    </div>

    <script>
        // 设置预设值
        function setStations(value) {
            document.getElementById('stations').value = value;
            updateCalculation();

            // 更新按钮状态
            document.querySelectorAll('.preset-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
        }

        // 更新计算
        function updateCalculation() {
            // 获取输入值
            const stations = parseInt(document.getElementById('stations').value);
            const investmentPerStation = parseInt(document.getElementById('investmentPerStation').value);
            const dailyCharging = parseInt(document.getElementById('dailyCharging').value);
            const serviceFee = parseFloat(document.getElementById('serviceFee').value);
            const operatingCostRate = parseInt(document.getElementById('operatingCost').value) / 100;

            // 更新显示值
            document.getElementById('stationsValue').textContent = stations;
            document.getElementById('investmentPerStationValue').textContent = investmentPerStation;
            document.getElementById('dailyChargingValue').textContent = dailyCharging;
            document.getElementById('serviceFeeValue').textContent = serviceFee.toFixed(2);
            document.getElementById('operatingCostValue').textContent = Math.round(operatingCostRate * 100);

            // 计算总投资（万元 -> 亿元）
            const totalInvestmentWan = stations * investmentPerStation;
            const totalInvestment = totalInvestmentWan / 10000;

            // 计算年收入（万元 -> 亿元）
            // 年收入 = 日充电量 × 365 × 服务费 × 站数
            const annualRevenueWan = dailyCharging * 365 * serviceFee * stations / 10000;
            const annualRevenue = annualRevenueWan / 10000;

            // 计算年利润（万元 -> 亿元）
            const annualProfitWan = annualRevenueWan * (1 - operatingCostRate);
            const annualProfit = annualProfitWan / 10000;

            // 计算投资回收期（年）
            const paybackPeriod = totalInvestment / annualProfit;

            // 计算IRR（简化版，实际应使用迭代法）
            // 基准IRR为42.8%，根据参数调整
            const baseIRR = 42.8;
            const chargingFactor = (dailyCharging / 1500);
            const feeFactor = (serviceFee / 0.6);
            const costFactor = ((1 - operatingCostRate) / 0.35);
            const irr = baseIRR * chargingFactor * feeFactor * costFactor;

            // 计算10年ROI
            const totalProfit10Years = annualProfit * 10;
            const roi = ((totalProfit10Years - totalInvestment) / totalInvestment) * 100;

            // 更新结果显示
            document.getElementById('totalInvestment').textContent = totalInvestment.toFixed(1);
            document.getElementById('annualRevenue').textContent = annualRevenue.toFixed(2);
            document.getElementById('annualProfit').textContent = annualProfit.toFixed(2);
            document.getElementById('paybackPeriod').textContent = paybackPeriod.toFixed(1);
            document.getElementById('irr').textContent = irr.toFixed(1);
            document.getElementById('roi').textContent = Math.round(roi);

            // 更新敏感性分析
            updateSensitivityAnalysis(dailyCharging, serviceFee, investmentPerStation, operatingCostRate);
        }

        // 更新敏感性分析
        function updateSensitivityAnalysis(charging, fee, investment, costRate) {
            // 充电量影响（±20%）
            const chargingLow = calculateIRR(charging * 0.8, fee, investment, costRate);
            const chargingHigh = calculateIRR(charging * 1.2, fee, investment, costRate);
            document.getElementById('sensitivityCharging').textContent =
                chargingLow.toFixed(1) + '% - ' + chargingHigh.toFixed(1) + '%';

            // 服务费影响（±20%）
            const feeLow = calculateIRR(charging, fee * 0.8, investment, costRate);
            const feeHigh = calculateIRR(charging, fee * 1.2, investment, costRate);
            document.getElementById('sensitivityFee').textContent =
                feeLow.toFixed(1) + '% - ' + feeHigh.toFixed(1) + '%';

            // 投资成本影响（±20%）
            const investLow = calculateIRR(charging, fee, investment * 0.8, costRate);
            const investHigh = calculateIRR(charging, fee, investment * 1.2, costRate);
            document.getElementById('sensitivityInvestment').textContent =
                investLow.toFixed(1) + '% - ' + investHigh.toFixed(1) + '%';
        }

        // 计算IRR的辅助函数
        function calculateIRR(charging, fee, investment, costRate) {
            const stations = parseInt(document.getElementById('stations').value);
            const baseIRR = 42.8;
            const chargingFactor = (charging / 1500);
            const feeFactor = (fee / 0.6);
            const investFactor = (280 / investment); // 反向关系
            const costFactor = ((1 - costRate) / 0.35);

            return baseIRR * chargingFactor * feeFactor * investFactor * costFactor;
        }

        // 页面加载时执行一次计算
        window.addEventListener('load', updateCalculation);

        // 淡入动画
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('visible');
            });
        }, {threshold: 0.1, rootMargin: '0px 0px -50px 0px'});
        document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>
</body>
</html>
